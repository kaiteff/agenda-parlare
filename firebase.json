{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "./",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "_backups/**",
      "backup_*/**",
      "backups/**",
      "old/**",
      "**/old/**",
      "**/*.zip",
      "**/*.rar",
      "**/*.7z",
      "**/*.tar",
      "**/*.gz",
      "*.zip",
      "*.rar",
      "*.pdf",
      "*.docx",
      "whats_app_webhook.py",
      "requirements.txt",
      "render.yaml",
      "serve.py"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
